[
  {
    "name": "/status shows bot status",
    "steps": [
      {
        "send": { "text": "/status" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "📊 Status\n\nBot is not configured yet. Tap ⚙️ Setup to get started."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Status button shows bot status",
    "steps": [
      {
        "send": { "callback": "status:show" },
        "expect": [{ "method": "editMessageText" }]
      }
    ]
  }
]
